NODE_ENV=production
APP_ENV=production

# Replace this with the public origin for your deployment.
WEB_ORIGIN=https://your-domain.example
API_PROXY_TARGET=http://api:8787

# App login bootstrap. Existing BASIC_AUTH_USER/PASSWORD are also accepted as
# bootstrap fallback so older CVM configs keep working after deployment.
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=change-this-admin-password
AUTH_BOOTSTRAP_PASSWORD_B64=
AUTH_BOOTSTRAP_SYNC_PASSWORD=false
AUTH_SESSION_DAYS=30
AUTH_COOKIE_SECURE=false

# Optional extra browser-level Basic Auth gate. Keep false for mainland tester UX.
BASIC_AUTH_ENABLED=false
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-this-login-password
NEXT_PUBLIC_RECHARGE_WECHAT_QR_URL=
NEXT_PUBLIC_RECHARGE_ALIPAY_QR_URL=

# Used only by docker-compose.cvm.yml for the internal Postgres container.
POSTGRES_PASSWORD=change-this-to-a-long-random-password

MOCK_PROVIDERS=false

# OpenAI keys are server-only. Never add NEXT_PUBLIC_OPENAI_* or VITE_OPENAI_*.
OPENAI_MOCK=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_BASE_URL=
OPENAI_API_MODE=responses
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2.6
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
OPENAI_MAX_COMPLETION_TOKENS=32000
OPENAI_TEXT_TIMEOUT_MS=360000
OPENAI_FALLBACK_TO_MOCK_ON_TIMEOUT=true

SEEDANCE_MOCK=false
SEEDANCE_API_KEY=
SEEDANCE_PROVIDER=ark
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_AUTH_SCHEME=Bearer
SEEDANCE_IMAGE_MODEL=doubao-seedream-4-0-250828
SEEDANCE_IMAGE_SIZE=1728x2304
SEEDANCE_IMAGE_ENHANCE_MODE=standard
SEEDANCE_VIDEO_MODEL=doubao-seedance-2-0-260128
SEEDANCE_VIDEO_RESOLUTION=720p
SEEDANCE_GENERATE_AUDIO=true
SEEDANCE_HTTP_TIMEOUT_SEC=120
SEEDANCE_VIDEO_SYNC_TIMEOUT_MS=180000
SEEDANCE_VIDEO_POLL_INTERVAL_MS=5000

# Single-CVM test deployment uses Docker volumes, not COS.
STORAGE_PROVIDER=local
