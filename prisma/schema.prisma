generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id                 String           @id
  ownerUserId        String?
  title              String
  inspiration        String
  status             String
  storyState         Json
  characterModels    Json
  sceneModels        Json
  videoFlows         Json
  assets             Json
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  mediaAssets        MediaAsset[]
  generationJobs     GenerationJob[]
  characterModelRows CharacterModel[]
  sceneModelRows     SceneModel[]
  videoFlowRows      VideoFlow[]
  workflowEdgeRows   WorkflowEdge[]
  ownerUser          AppUser?         @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  usageLogs          UsageLog[]

  @@index([ownerUserId])
}

model AppUser {
  id                         String        @id
  username                   String        @unique
  email                      String?       @unique
  emailVerifiedAt            DateTime?
  emailVerificationTokenHash String?       @unique
  emailVerificationExpiresAt DateTime?
  emailVerificationSentAt    DateTime?
  displayName                String?
  passwordHash               String
  role                       String
  status                     String        @default("active")
  billingMode                String        @default("free")
  coinBalance                Int           @default(0)
  note                       String?
  lastLoginAt                DateTime?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  projects                   Project[]
  sessions                   AuthSession[]
  usageLogs                  UsageLog[]
  coinLedgers                CoinLedger[]
  rechargeRequests           RechargeRequest[]
  passwordResetRequests      PasswordResetRequest[]

  @@index([role])
  @@index([status])
  @@index([billingMode])
  @@index([emailVerifiedAt])
}

model CoinLedger {
  id           String   @id
  userId       String
  delta        Int
  balanceAfter Int
  type         String
  action       String?
  projectId    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model RechargeRequest {
  id               String    @id
  userId           String
  paymentMethod    String
  amountCny        Int
  coins            Int
  status           String    @default("pending")
  note             String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PasswordResetRequest {
  id               String    @id
  userId           String
  contact          String?
  status           String    @default("pending")
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model AuthSession {
  id        String    @id
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UsageLog {
  id        String   @id
  userId    String?
  projectId String?
  action    String
  model     String?
  status    String
  metadata  Json?
  createdAt DateTime @default(now())

  user    AppUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([action])
  @@index([createdAt])
}

model MediaAsset {
  id         String   @id
  projectId  String
  type       String
  url        String
  storageKey String?
  provider   String
  prompt     String
  jobId      String?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([jobId])
}

model GenerationJob {
  id             String   @id
  projectId      String
  targetType     String
  targetId       String
  provider       String
  model          String
  status         String
  requestPayload Json
  resultPayload  Json?
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([targetType, targetId])
}

model CharacterModel {
  id                String   @id
  projectId         String
  characterId       String
  name              String
  description       String
  consistencyPrompt String
  sortOrder         Int      @default(0)
  imageAspectRatio  String?
  candidateImages   Json
  confirmedImageId  String?
  status            String
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([characterId])
  @@index([status])
}

model SceneModel {
  id               String   @id
  projectId        String
  name             String
  description      String
  sortOrder        Int      @default(0)
  visualKeywords   Json
  generationPrompt String?
  imageAspectRatio String?
  candidateImages  Json
  confirmedImageId String?
  status           String
  error            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

model VideoFlow {
  id                        String   @id
  projectId                 String
  shotId                    String
  sortOrder                 Int      @default(0)
  nodes                     Json
  selectedCharacterModelId  String?
  selectedSceneModelId      String?
  selectedCharacterModelIds Json
  selectedSceneModelIds     Json
  imagePrompt               String?
  imagePromptImageUrl       String?
  imagePromptImageName      String?
  prompt                    String
  actionDescription         String
  emotion                   String
  cameraMovement            String
  durationSeconds           Int
  aspectRatio               String
  videoAssetId              String?
  pendingVideoJobId         String?
  status                    String
  error                     String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([shotId])
  @@index([status])
}

model WorkflowEdge {
  id         String   @id
  projectId  String
  sourceType String
  sourceId   String
  sourcePort String
  targetType String
  targetId   String
  targetPort String
  kind       String
  sortOrder  Int      @default(0)
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@index([kind])
}
