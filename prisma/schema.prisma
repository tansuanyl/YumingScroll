generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id                 String           @id
  title              String
  inspiration        String
  status             String
  storyState         Json
  characterModels    Json
  sceneModels        Json
  videoFlows         Json
  assets             Json
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  mediaAssets        MediaAsset[]
  generationJobs     GenerationJob[]
  characterModelRows CharacterModel[]
  sceneModelRows     SceneModel[]
  videoFlowRows      VideoFlow[]
  workflowEdgeRows   WorkflowEdge[]
}

model MediaAsset {
  id         String   @id
  projectId  String
  type       String
  url        String
  storageKey String?
  provider   String
  prompt     String
  jobId      String?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([jobId])
}

model GenerationJob {
  id             String   @id
  projectId      String
  targetType     String
  targetId       String
  provider       String
  model          String
  status         String
  requestPayload Json
  resultPayload  Json?
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([targetType, targetId])
}

model CharacterModel {
  id                String   @id
  projectId         String
  characterId       String
  name              String
  description       String
  consistencyPrompt String
  sortOrder         Int      @default(0)
  imageAspectRatio  String?
  candidateImages   Json
  confirmedImageId  String?
  status            String
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([characterId])
  @@index([status])
}

model SceneModel {
  id               String   @id
  projectId        String
  name             String
  description      String
  sortOrder        Int      @default(0)
  visualKeywords   Json
  generationPrompt String?
  imageAspectRatio String?
  candidateImages  Json
  confirmedImageId String?
  status           String
  error            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

model VideoFlow {
  id                        String   @id
  projectId                 String
  shotId                    String
  sortOrder                 Int      @default(0)
  nodes                     Json
  selectedCharacterModelId  String?
  selectedSceneModelId      String?
  selectedCharacterModelIds Json
  selectedSceneModelIds     Json
  imagePrompt               String?
  imagePromptImageUrl       String?
  imagePromptImageName      String?
  prompt                    String
  actionDescription         String
  emotion                   String
  cameraMovement            String
  durationSeconds           Int
  aspectRatio               String
  videoAssetId              String?
  pendingVideoJobId         String?
  status                    String
  error                     String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([shotId])
  @@index([status])
}

model WorkflowEdge {
  id         String   @id
  projectId  String
  sourceType String
  sourceId   String
  sourcePort String
  targetType String
  targetId   String
  targetPort String
  kind       String
  sortOrder  Int      @default(0)
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@index([kind])
}
