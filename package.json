{
  "name": "ai-comic-workbench",
  "version": "0.1.1",
  "description": "An AI-assisted comic drama creation workbench for story, storyboard, visual assets, Flow Map, and video generation.",
  "private": true,
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tansuanyl/YumingScroll.git"
  },
  "bugs": {
    "url": "https://github.com/tansuanyl/YumingScroll/issues"
  },
  "homepage": "https://github.com/tansuanyl/YumingScroll#readme",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:client": "npm run dev:web",
    "dev:web": "next dev --webpack -H 127.0.0.1 -p 5173",
    "dev:server": "tsx watch server/main.ts",
    "start:web": "next start -H 127.0.0.1 -p 5173",
    "start:server": "tsx server/main.ts",
    "build": "npm run build:web",
    "build:web": "npm run db:generate && npm run typecheck && next build",
    "build:server": "npm run db:generate && npm run typecheck",
    "verify:client-secrets": "node scripts/verify-no-public-openai-secrets.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "prisma": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.25.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.10",
    "openai": "^6.48.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/vite": "^4.3.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "esbuild": "0.28.1",
    "hono": "4.12.29",
    "postcss": "8.5.16",
    "qs": "6.15.3"
  }
}
